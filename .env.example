# ── Server ───────────────────────────────────────────────
# Railway provides PORT automatically — do not set it manually there.
PORT=3000

NODE_ENV=production
LOG_LEVEL=info

# ── Database (Neon) ───────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details.
# Use the "pooled" connection string (ends with ?sslmode=require).
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# ── Auth (OpenID Connect) ─────────────────────────────────
# ISSUER_URL: the OIDC discovery endpoint of your auth provider.
#   Replit:  https://replit.com/oidc
#   Auth0:   https://YOUR_DOMAIN.auth0.com
#   Google:  https://accounts.google.com
ISSUER_URL=https://replit.com/oidc

# OIDC_CLIENT_ID: the client/app ID from your auth provider.
#   (Previously called REPL_ID on Replit)
OIDC_CLIENT_ID=your_client_id_here

# OIDC_CLIENT_SECRET: required by some providers (Auth0, Google, etc.).
# Leave unset for public/PKCE-only clients (e.g. Replit).
# OIDC_CLIENT_SECRET=your_client_secret_here

# ── Ticketmaster ──────────────────────────────────────────
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here
