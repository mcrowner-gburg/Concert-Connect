# ── Server ───────────────────────────────────────────────
# Railway provides PORT automatically — do not set it manually there.
PORT=3000

NODE_ENV=production
LOG_LEVEL=info

# ── Database (Neon) ───────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details.
# Use the "pooled" connection string (ends with ?sslmode=require).
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# ── Admin ────────────────────────────────────────────────
# The account with this email is automatically promoted to admin on login.
# Set this to your email address.
ADMIN_EMAIL=you@example.com

# ── Ticketmaster ──────────────────────────────────────────
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# ── Cloudflare R2 (file uploads) ─────────────────────────
# Account ID from dash.cloudflare.com (right sidebar)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# R2 bucket name (create one at Cloudflare → R2 → Create Bucket)
R2_BUCKET_NAME=concert-connect

# R2 API token credentials (Cloudflare → R2 → Manage R2 API Tokens)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Optional: custom public domain for R2 bucket (if you set one up)
# Otherwise objects are accessed via r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://files.yourdomain.com

# ── Resend (email) ────────────────────────────────────────
# RESEND_API_KEY=your_resend_api_key_here
# EMAIL_FROM=noreply@yourdomain.com
